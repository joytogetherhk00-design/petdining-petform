{
  "name": "Enrollments",
  "type": "object",
  "properties": {
    "enrollment_id": {
      "type": "string",
      "description": "\u5831\u540d\u7de8\u865f"
    },
    "course_id": {
      "type": "string",
      "description": "\u8ab2\u7a0b ID"
    },
    "course_title": {
      "type": "string",
      "description": "\u8ab2\u7a0b\u540d\u7a31"
    },
    "user_email": {
      "type": "string",
      "description": "\u7528\u6236\u96fb\u90f5"
    },
    "user_name": {
      "type": "string",
      "description": "\u7528\u6236\u540d\u7a31"
    },
    "student_name": {
      "type": "string",
      "description": "\u5b78\u54e1\u59d3\u540d"
    },
    "student_id": {
      "type": "string",
      "description": "\u5b78\u54e1\u8eab\u4efd\u8b49\u865f\u78bc\uff08\u524d 4 \u4f4d\uff09"
    },
    "student_gender": {
      "type": "string",
      "description": "\u5b78\u54e1\u6027\u5225"
    },
    "student_phone": {
      "type": "string",
      "description": "\u5b78\u54e1\u806f\u7d61\u96fb\u8a71"
    },
    "student_email": {
      "type": "string",
      "description": "\u5b78\u54e1\u96fb\u90f5"
    },
    "company": {
      "type": "string",
      "description": "\u6240\u5c6c\u516c\u53f8"
    },
    "branch": {
      "type": "string",
      "description": "\u5206\u5e97"
    },
    "schedule_id": {
      "type": "string",
      "description": "\u8ab2\u7a0b\u6642\u9593\u8868 ID"
    },
    "schedule_date": {
      "type": "string",
      "format": "date-time",
      "description": "\u8ab2\u7a0b\u65e5\u671f"
    },
    "schedule_end": {
      "type": "string",
      "format": "date-time",
      "description": "\u8ab2\u7a0b\u7d50\u675f\u6642\u9593"
    },
    "location": {
      "type": "string",
      "description": "\u4e0a\u8ab2\u5730\u9ede"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "stripe",
        "quota"
      ],
      "description": "\u652f\u4ed8\u65b9\u5f0f\uff1astripe\uff08\u4fe1\u7528\u5361\uff09/ quota\uff08\u5546\u696d\u5ba2\u6236\u540d\u984d\uff09"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "pending",
        "paid",
        "refunded"
      ],
      "default": "pending",
      "description": "\u652f\u4ed8\u72c0\u614b"
    },
    "stripe_session_id": {
      "type": "string",
      "description": "Stripe Session ID"
    },
    "amount_paid": {
      "type": "number",
      "description": "\u652f\u4ed8\u91d1\u984d\uff08HKD\uff09"
    },
    "quota_used": {
      "type": "boolean",
      "default": false,
      "description": "\u662f\u5426\u4f7f\u7528\u4e86 Quota \u540d\u984d"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "completed",
        "cancelled"
      ],
      "default": "pending",
      "description": "\u5831\u540d\u72c0\u614b"
    },
    "enrollment_date": {
      "type": "string",
      "format": "date-time",
      "description": "\u5831\u540d\u65e5\u671f"
    },
    "completion_certificate": {
      "type": "boolean",
      "default": false,
      "description": "\u662f\u5426\u5df2\u7372\u5f97\u8b49\u66f8"
    },
    "attendance_status": {
      "type": "string",
      "enum": [
        "not_checked",
        "attended",
        "absent",
        "late"
      ],
      "default": "not_checked",
      "description": "\u51fa\u5e2d\u72c0\u614b"
    },
    "attendance_checked_at": {
      "type": "string",
      "format": "date-time",
      "description": "\u7c3d\u5230\u6642\u9593"
    },
    "attendance_checked_by": {
      "type": "string",
      "description": "\u7c3d\u5230\u7ba1\u7406\u54e1"
    },
    "attendance_notes": {
      "type": "string",
      "description": "\u5099\u8a3b"
    }
  },
  "required": [
    "course_id",
    "user_email",
    "payment_method"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.user_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.user_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}